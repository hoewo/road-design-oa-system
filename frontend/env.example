# API configuration
# 新路由格式：/{service}/v1/{auth_level}/{path}
# 示例：http://localhost:8082/project-oa/v1/user/projects
REACT_APP_API_BASE_URL=http://localhost:8082/project-oa/v1
REACT_APP_API_TIMEOUT=10000
# 认证模式：self_validate (开发环境) 或 gateway (生产环境)
REACT_APP_AUTH_MODE=self_validate
# NebulaAuth服务地址（self_validate模式使用）
REACT_APP_NEBULA_AUTH_URL=http://localhost:8081

# File upload configuration
REACT_APP_MAX_FILE_SIZE=104857600
REACT_APP_ALLOWED_FILE_TYPES=.pdf,.doc,.docx,.xls,.xlsx,.ppt,.pptx,.jpg,.jpeg,.png

# Application configuration
REACT_APP_APP_NAME=项目管理OA系统
REACT_APP_VERSION=1.0.0
