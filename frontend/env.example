# API configuration
# 新路由格式：/{service}/v1/{auth_level}/{path}
# 示例：http://localhost:8080/project-oa/v1/user/projects

# 认证模式（重要：决定API地址和访问方式）
# gateway: 通过网关访问，API地址指向网关（默认 http://localhost:8080/project-oa/v1）
#   - 后端从Header读取用户信息（由网关处理认证）
#   - 适用于：生产环境、本地Docker部署网关的开发环境
# self_validate: 直接访问后端，API地址指向后端服务（默认 http://localhost:8082/project-oa/v1）
#   - 后端调用NebulaAuth API验证Token
#   - 适用于：本地开发，直接访问后端服务
VITE_AUTH_MODE=gateway

# 业务API基础地址（可选，如果不设置会根据 VITE_AUTH_MODE 自动选择）
# gateway模式默认：http://localhost:8080/project-oa/v1（通过网关）
# self_validate模式默认：http://localhost:8082/project-oa/v1（直接访问后端）
# 生产环境：http://your-aliyun-ip:8080/project-oa/v1（通过网关）
VITE_API_BASE_URL=http://localhost:8080/project-oa/v1

# NebulaAuth网关地址
# 开发环境：http://localhost:8080（本地NebulaAuth网关）
# 生产环境：http://your-aliyun-ip:8080（生产环境网关地址）
VITE_NEBULA_AUTH_URL=http://localhost:8080

# API请求超时时间（毫秒）
# 注意：当前代码中硬编码为10000，此配置项为预留，暂未使用
VITE_API_TIMEOUT=10000

# 文件上传配置
# 最大文件大小（字节），104857600 = 100MB
VITE_MAX_FILE_SIZE=104857600

# 允许的文件类型（逗号分隔）
VITE_ALLOWED_FILE_TYPES=.pdf,.doc,.docx,.xls,.xlsx,.ppt,.pptx,.jpg,.jpeg,.png

# 应用配置
VITE_APP_NAME=道路设计公司项目管理系统
VITE_VERSION=1.0.0
