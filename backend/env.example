# Database configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=project_oa
DB_USER=project_oa_user
DB_PASSWORD=project_oa_password
DB_SSL_MODE=disable
DB_TYPE=postgresql
# DB_TYPE options: postgresql (本地PostgreSQL) or rds (阿里云RDS)

# JWT configuration
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRE_HOURS=24

# Storage configuration
STORAGE_TYPE=minio
# STORAGE_TYPE options: minio (本地MinIO) or oss (阿里云OSS)

# MinIO configuration (when STORAGE_TYPE=minio)
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_NAME=project-files
MINIO_USE_SSL=false

# OSS configuration (when STORAGE_TYPE=oss)
OSS_ENDPOINT=oss-cn-hangzhou.aliyuncs.com
OSS_ACCESS_KEY_ID=your_oss_access_key_id
OSS_ACCESS_KEY_SECRET=your_oss_access_key_secret
OSS_BUCKET_NAME=project-oa-files

# Authentication configuration
AUTH_MODE=self_validate
# AUTH_MODE options: self_validate (开发环境，调用NebulaAuth API验证) or gateway (生产环境，从Header读取)
NEBULA_AUTH_URL=http://localhost:8081
SERVICE_NAME=project-oa
SERVICE_PORT=8080
SERVICE_HOST=
# SERVICE_HOST: 生产环境需要设置云端服务器IP（用于服务注册到NebulaAuth网关）

# Server configuration
SERVER_PORT=8080
SERVER_HOST=0.0.0.0
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Log configuration
LOG_LEVEL=info
LOG_FORMAT=json
