# Database configuration
DB_HOST=localhost
# DB_HOST: 数据库主机地址
#   - 开发环境: localhost
#   - 生产环境: RDS 端点地址，如 your-rds-endpoint
DB_PORT=5433
# DB_PORT: 数据库端口
#   - 开发环境: 5433（避免与系统PostgreSQL冲突）或 5432
#   - 生产环境: 5432（RDS标准端口）
DB_NAME=project_oa
DB_USER=project_oa_user
DB_PASSWORD=project_oa_password
DB_SSL_MODE=disable
# DB_SSL_MODE: 数据库SSL模式
#   - 开发环境: disable
#   - 生产环境: require（RDS需要SSL连接）
DB_TYPE=postgresql
# DB_TYPE options: 
#   - postgresql: 本地PostgreSQL（开发环境）
#   - rds: 阿里云RDS（生产环境）

# JWT configuration
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRE_HOURS=24

# Storage configuration
STORAGE_TYPE=minio
# STORAGE_TYPE options: 
#   - minio: 本地MinIO（开发环境）
#   - oss: 阿里云OSS（生产环境）

# MinIO configuration (when STORAGE_TYPE=minio)
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_NAME=project-files
MINIO_USE_SSL=false

# OSS configuration (when STORAGE_TYPE=oss)
OSS_ENDPOINT=oss-cn-hangzhou.aliyuncs.com
OSS_ACCESS_KEY_ID=your_oss_access_key_id
OSS_ACCESS_KEY_SECRET=your_oss_access_key_secret
OSS_BUCKET_NAME=project-oa-files

# Authentication configuration
AUTH_MODE=self_validate
# AUTH_MODE options: 
#   - self_validate: 开发环境，调用NebulaAuth API验证
#   - gateway: 生产环境，从Header读取用户信息（由网关处理认证）
NEBULA_AUTH_URL=http://localhost:8080
API_BASE_URL=http://localhost:8080
# API_BASE_URL: 客户端访问地址
#   - 开发环境: http://localhost:8080 或 http://localhost:8082
#   - 生产环境: 网关地址，如 http://your-aliyun-ip:8080
SERVICE_NAME=project-oa
SERVICE_PORT=8082
# SERVICE_PORT: 服务端口
#   - 开发环境: 8082（避免与网关冲突）
#   - 生产环境: 8080（或根据实际部署调整）
SERVICE_HOST=
# SERVICE_HOST: 云端服务器IP（用于服务注册到NebulaAuth网关）
#   - 开发环境: 留空或 localhost
#   - 生产环境: 必须设置，如 your-cloud-ip

# Server configuration
SERVER_PORT=8082
# SERVER_PORT: 服务器监听端口
#   - 开发环境: 8082（避免与网关冲突）
#   - 生产环境: 8080（或根据实际部署调整）
SERVER_HOST=0.0.0.0
CORS_ALLOWED_ORIGINS=http://localhost:3000
# CORS_ALLOWED_ORIGINS: 允许的前端域名
#   - 开发环境: http://localhost:3000
#   - 生产环境: 实际的前端域名，如 http://your-frontend-domain

# Log configuration
LOG_LEVEL=info
# LOG_LEVEL: 日志级别
#   - 开发环境: debug（详细日志）
#   - 生产环境: info（标准日志）
LOG_FORMAT=json
