# ============================================================================
# 项目环境配置示例（统一配置文件）
# ============================================================================
# 此文件整合了后端、前端和部署相关的所有配置
# 
# 配置分类说明：
#   1. 业务服务部署配置：业务服务自身运行所需（SERVER_HOST/SERVER_PORT）
#   2. 服务注册配置：向星云Auth注册业务服务所需（SERVICE_HOST/SERVICE_PORT）
#   3. 业务应用配置：业务服务功能配置（数据库、存储、认证等）
#   4. 前端配置：前端应用所需配置（VITE_ 开头）
# 
# 重要概念区分：
#   - 业务服务部署参数（SERVER_HOST/SERVER_PORT）：业务服务在容器内监听什么地址和端口
#   - 服务注册参数（SERVICE_HOST/SERVICE_PORT）：告诉星云Auth网关如何访问业务服务
#   - 这两者不是一回事，但在某些情况下可能相同（如 Docker 同网络部署）
# 
# 使用方法：
#   1. 本地开发：复制为 .env: cp env.example .env
#   2. 生产部署：复制为 .env: cp env.example .env，然后修改生产环境配置
#   3. 后端服务会从项目根目录的 .env 读取配置
#   4. 前端服务会从项目根目录的 .env 读取 VITE_ 开头的环境变量
# ============================================================================

# ============================================================================
# 部署配置（仅用于生产环境部署）
# ============================================================================

# 生产服务器地址（IP 或域名）
# 本地开发时可以不设置
PROD_SERVER_HOST=your-server-ip-or-domain

# SSH 用户名
PROD_SERVER_USER=root

# 远程服务器项目目录（部署路径）
PROD_SERVER_PROJECT_DIR=/root/workspace/road-design-oa-system

# SSH 认证配置（二选一）
# 方式1: 使用 SSH 密钥认证（推荐）
PROD_SSH_KEY=~/.ssh/id_rsa

# 方式2: 使用密码认证（使用密钥认证时留空）
# PROD_SSH_PASSWORD=your-ssh-password

# 注意：如果同时设置了 PROD_SSH_KEY 和 PROD_SSH_PASSWORD，优先使用密钥认证

# 注意：远程注册模式在本地执行注册脚本，不需要远程服务器上有注册脚本或 jq

# ============================================================================
# 数据库配置
# ============================================================================

# 数据库类型: postgresql (本地PostgreSQL) 或 rds (阿里云RDS)
#   - 开发环境: postgresql
#   - 生产环境: postgresql 或 rds
DB_TYPE=postgresql

# 数据库主机地址
#   - 开发环境（本地）: localhost
#   - 开发环境（Docker）: postgres (Docker Compose 服务名)
#   - 生产环境（Docker）: postgres
#   - 生产环境（RDS）: your-rds-endpoint.rds.aliyuncs.com
DB_HOST=postgres

# 数据库端口
#   - 开发环境（本地）: 5433（避免与系统PostgreSQL冲突）
#   - 开发环境（Docker）: 5432
#   - 生产环境（Docker）: 5432
#   - 生产环境（RDS）: 5432
DB_PORT=5432

# PostgreSQL 容器端口映射（仅用于 Docker Compose）
#   - 开发环境: 5433（避免与系统PostgreSQL冲突）
#   - 生产环境: 5432
POSTGRES_PORT=5433

# 数据库名称
DB_NAME=project_oa

# 数据库用户名
DB_USER=project_oa_user

# 数据库密码
#   - 开发环境: project_oa_password（默认）
#   - 生产环境: 请使用强密码
DB_PASSWORD=project_oa_password

# 数据库 SSL 模式
#   - 开发环境: disable
#   - 生产环境（RDS）: require
DB_SSL_MODE=disable

# ============================================================================
# 存储配置
# ============================================================================

# 存储类型: minio (本地MinIO) 或 oss (阿里云OSS)
#   - 开发环境: minio
#   - 生产环境: minio 或 oss
STORAGE_TYPE=minio

# MinIO 配置（当 STORAGE_TYPE=minio 时）
#   - 开发环境（本地）: localhost:9000
#   - 开发环境（Docker）: minio:9000
#   - 生产环境（Docker）: minio:9000
MINIO_ENDPOINT=minio:9000

# MinIO 访问密钥
#   - 开发环境: minioadmin（默认）
#   - 生产环境: 请使用强密钥
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# MinIO 存储桶名称
MINIO_BUCKET_NAME=project-files

# MinIO 是否使用 SSL
MINIO_USE_SSL=false

# MinIO 端口映射（仅用于 Docker Compose）
#   - API 端口（默认: 9000）
MINIO_API_PORT=9000
#   - 控制台端口（默认: 9001）
MINIO_CONSOLE_PORT=9001

# OSS 配置（当 STORAGE_TYPE=oss 时）
# OSS_ENDPOINT=oss-cn-hangzhou.aliyuncs.com
# OSS_ACCESS_KEY_ID=your-oss-access-key-id
# OSS_ACCESS_KEY_SECRET=your-oss-access-key-secret
# OSS_BUCKET_NAME=project-oa-files

# ============================================================================
# 后端应用配置
# ============================================================================

# 认证模式
#   - self_validate: 直接访问后端，后端调用NebulaAuth API验证Token（开发环境）
#   - gateway: 通过网关访问，后端从Header读取用户信息（生产环境推荐）
AUTH_MODE=gateway

# NebulaAuth 网关地址（星云Auth服务地址）
#   - 开发环境: http://localhost:8080
#   - 生产环境（Docker 同网络）: http://nebula-auth-container:8080 或 http://gateway-ip:8080
#   - 生产环境（不同服务器）: http://your-gateway-ip:8080
#   - 用途：
#     * self_validate 模式：业务服务调用此地址验证 Token
#     * gateway 模式：前端访问此地址，网关负责路由
NEBULA_AUTH_URL=http://localhost:8080

# API 基础地址（客户端访问地址）
#   - 开发环境（self_validate）: http://localhost:8082（直接访问业务服务）
#   - 开发环境（gateway）: http://localhost:8080（通过网关访问）
#   - 生产环境（gateway）: http://your-gateway-ip:8080（通过网关访问）
#   - 用途：前端调用业务 API 时使用此地址
API_BASE_URL=http://localhost:8082

# 服务名称（业务服务标识）
#   - 用于路由：网关会根据此名称路由请求到对应的业务服务
#   - 用于注册：服务注册时使用此名称
#   - 注意：此名称必须与服务注册时的名称一致
SERVICE_NAME=project-oa

# ============================================================================
# 业务服务部署配置（业务服务自身运行所需）
# ============================================================================
# 这些配置用于业务服务自身的启动和运行，与星云Auth网关无关

# SERVER_HOST: 业务服务在容器内绑定的监听地址
#   - 通常设置为 0.0.0.0（监听所有网络接口）
#   - 不建议修改，除非有特殊需求
#   - 用途：业务服务启动时绑定此地址
SERVER_HOST=0.0.0.0

# SERVER_PORT: 业务服务在容器内监听的端口
#   - 开发环境: 8082（避免与网关冲突）
#   - 生产环境: 8082（或根据实际部署调整）
#   - 注意：这是容器内的端口，外部访问需要通过 Docker 端口映射
#   - 用途：业务服务启动时监听此端口
SERVER_PORT=8082

# ============================================================================
# 服务注册配置（告诉星云Auth网关如何访问此业务服务）
# ============================================================================
# 这些配置用于向星云Auth服务注册中心注册业务服务
# 星云Auth网关会根据这些配置来路由请求到业务服务
# 
# 重要说明：
#   - 业务服务部署参数（SERVER_HOST/SERVER_PORT）和服务注册参数（SERVICE_HOST/SERVICE_PORT）
#     不是一回事，但有关系：
#     * SERVER_HOST/SERVER_PORT：业务服务在容器内监听什么地址和端口
#     * SERVICE_HOST/SERVICE_PORT：网关需要知道如何访问业务服务
#   - 部署场景：
#     * 同服务器Docker：SERVICE_HOST 可以使用容器名（如 backend），SERVICE_PORT 通常与 SERVER_PORT 相同
#     * 不同服务器：SERVICE_HOST 必须是业务服务器的实际 IP 或域名，SERVICE_PORT 可能是外部映射端口

# SERVICE_HOST: 业务服务注册地址（网关访问业务服务的地址）
#   - 开发环境: 留空或 localhost（开发环境通常不需要注册）
#   - 生产环境（Docker 同网络）: 容器名（如 backend）或 Docker 网络 IP
#   - 生产环境（不同服务器）: 业务服务器的公网 IP 或域名（必须设置）
#   - 注意：不要使用 127.0.0.1 或 localhost，网关无法访问
#   - 用途：服务注册时告诉网关如何访问业务服务
SERVICE_HOST=backend

# SERVICE_PORT: 业务服务注册端口（网关访问业务服务的端口）
#   - 开发环境: 8082（开发环境通常不需要注册）
#   - 生产环境（Docker 同网络）: 通常与 SERVER_PORT 相同（容器内端口）
#   - 生产环境（不同服务器）: 外部映射的端口（可能与 SERVER_PORT 不同）
#   - 用途：服务注册时告诉网关如何访问业务服务
SERVICE_PORT=8082

# CORS 允许的源（前端域名）
#   - 开发环境: http://localhost:3000
#   - 生产环境: http://your-frontend-domain
CORS_ALLOWED_ORIGINS=http://localhost:3000

# ============================================================================
# JWT 配置
# ============================================================================

# JWT 密钥
#   - 开发环境: your_jwt_secret_key_here（默认）
#   - 生产环境: 请使用强随机密钥
JWT_SECRET=your_jwt_secret_key_here

# JWT 过期时间（小时）
JWT_EXPIRE_HOURS=24

# ============================================================================
# 日志配置
# ============================================================================

# 日志级别: debug, info, warn, error
#   - 开发环境: debug（详细日志）
#   - 生产环境: info（标准日志）
LOG_LEVEL=debug

# 日志格式: json, text
#   - 开发环境: text（可读性更好）
#   - 生产环境: json（便于日志收集）
LOG_FORMAT=text

# ============================================================================
# Docker Compose 配置（仅用于 Docker 部署）
# ============================================================================

# 容器重启策略
#   - no: 不自动重启
#   - always: 总是重启
#   - on-failure: 失败时重启
#   - unless-stopped: 除非手动停止，否则总是重启（推荐生产环境）
RESTART_POLICY=unless-stopped

# 前端端口映射（仅用于 Docker Compose）
FRONTEND_PORT=3000

# ============================================================================
# 前端环境变量（Vite）
# ============================================================================
# 注意：Vite 环境变量必须以 VITE_ 开头
# 这些变量会在构建时注入到前端代码中
# 开发环境（npm run dev）会从 .env.local 或 .env 读取

# 认证模式（前端）
#   - gateway: 通过网关访问，API地址指向网关（生产环境、本地Docker部署网关的开发环境）
#   - self_validate: 直接访问后端，API地址指向后端服务（本地开发，直接访问后端服务）
VITE_AUTH_MODE=self_validate

# 业务API基础地址（前端）
#   - gateway模式: http://localhost:8080/project-oa/v1（通过网关）
#   - self_validate模式: http://localhost:8082/project-oa/v1（直接访问后端）
#   - 生产环境: http://your-gateway-ip:8080/project-oa/v1（通过网关）
VITE_API_BASE_URL=http://localhost:8082/project-oa/v1

# NebulaAuth网关地址（前端）
#   - 开发环境: http://localhost:8080（本地NebulaAuth网关）
#   - 生产环境: http://your-gateway-ip:8080（生产环境网关地址）
VITE_NEBULA_AUTH_URL=http://localhost:8080

# API请求超时时间（毫秒）
# 注意：当前代码中硬编码为10000，此配置项为预留，暂未使用
VITE_API_TIMEOUT=10000

# 文件上传配置
# 最大文件大小（字节），104857600 = 100MB
VITE_MAX_FILE_SIZE=104857600

# 允许的文件类型（逗号分隔）
VITE_ALLOWED_FILE_TYPES=.pdf,.doc,.docx,.xls,.xlsx,.ppt,.pptx,.jpg,.jpeg,.png

# 应用信息
VITE_APP_NAME=道路设计公司项目管理系统
VITE_VERSION=1.0.0

# ============================================================================
# 监控配置（可选）
# ============================================================================

# 如果使用 Prometheus 监控，可以配置以下变量
# PROMETHEUS_PORT=9090
# ALERTMANAGER_PORT=9093

# ============================================================================
# 配置说明
# ============================================================================
#
# 本地开发环境配置说明：
#   - 使用 start.sh 启动本地开发环境
#   - 后端从项目根目录的 .env 读取配置（或从 backend/.env）
#   - 前端从项目根目录的 .env 读取 VITE_ 开头的环境变量（或从 frontend/.env.local）
#   - 数据库使用本地 PostgreSQL（端口 5433）
#   - MinIO 使用本地服务（端口 9000/9001）
#
# Docker 开发环境配置说明：
#   - 使用 docker compose up 启动
#   - 所有配置从项目根目录的 .env 读取
#   - docker-compose.yml 会自动使用环境变量替换配置
#
# 生产环境部署说明：
#   - 使用 scripts/deploy-prod.sh 部署
#   - 修改此文件中的生产环境配置（服务器地址、密码等）
#   - 部署脚本会自动上传 .env 到服务器
#
# ============================================================================
# 安全提示
# ============================================================================
# 
# ⚠️  重要安全提示：
# 
# 1. 此文件包含敏感信息，请勿提交到版本控制系统
# 2. 生产环境请使用强密码和密钥
# 3. 定期轮换密钥和密码
# 4. 限制 .env 文件的访问权限: chmod 600 .env
# 5. 使用密钥认证而非密码认证（更安全）
# 
# ============================================================================